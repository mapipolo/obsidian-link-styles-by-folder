{
  "name": "link-styles-by-folder",
  "version": "1.0.0",
  "description": "Applies per-folder link style rules so notes in different folders automatically use their configured link format.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "links",
    "wikilinks"
  ],
  "author": "Michael Pipolo <mapipolo@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.60.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.0.0"
  }
}
